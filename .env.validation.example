# General
VALIDATION_MODE=local
ALLOW_INVALID_CERTS=true

# Local stack example
BASE_URL=http://localhost:8080
AUTH_PATH=/auth/token

# Deployment example
# BASE_URL=https://10.43.101.28/api
# AUTH_PATH=/auth/token

# Optional infra for core validation
DATABASE_URL=postgresql://mipit:mipit_secret@localhost:5432/mipit
RABBITMQ_URL=amqp://mipit:mipit_secret@localhost:5672/mipit
PIX_MOCK_URL=http://localhost:9001
SPEI_MOCK_URL=http://localhost:9002
BREB_MOCK_URL=http://localhost:9003

# Suite toggles
RUN_REPO_TESTS=true
RUN_CORE_E2E=true
RUN_HISTORICAL_SCRIPTS=true
RUN_BENCHMARKS=true
RUN_RESILIENCE=true

# Tunables for lighter local runs
LOAD_TOTAL_REQUESTS=100
LOAD_CONCURRENCY=10
BENCHMARK_DURATION_S=5
BENCHMARK_RPS_TARGET=20
